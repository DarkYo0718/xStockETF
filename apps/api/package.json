{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node node_modules/@nestjs/cli/bin/nest.js build",
    "dev": "node node_modules/@nestjs/cli/bin/nest.js start --watch",
    "lint": "node node_modules/typescript/bin/tsc --noEmit -p tsconfig.json",
    "refresh:active-etfs": "node --loader ts-node/esm ./scripts/refresh-active-etfs.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
    "typecheck": "node node_modules/typescript/bin/tsc --noEmit -p tsconfig.json",
    "format": "echo \"No formatter configured for api\"",
    "prisma": "node node_modules/prisma/build/index.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.2",
    "@nestjs/core": "^10.4.2",
    "@nestjs/platform-express": "^10.4.2",
    "@prisma/client": "^5.15.1",
    "@xstocketf/types": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.2",
    "@nestjs/testing": "^10.4.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "prisma": "^5.15.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
